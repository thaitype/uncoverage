{
  "name": "uncoverage",
  "version": "0.1.0",
  "type": "module",
  "description": "Extract uncovered lines from Istanbul coverage reports — with context — ready to paste into ChatGPT, Claude, or Gemini for debugging or test generation.",
  "main": "./dist/main.js",
  "module": "./dist/main.mjs",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.mjs",
      "default": "./dist/main.js"
    }
  },
  "bin": {
    "uncoverage": "bin.mjs"
  },
  "files": [
    "bin.mjs",
    "dist",
    "src",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "all": "run-s lint build",
    "build": "tsup src/main.ts --dts --format esm,cjs",
    "release": "npm run build && changeset publish",
    "lint": "tsc --noEmit",
    "test": "ava",
    "local:run": " pnpm build && npx uncoverage . --output xxx.md",
    "upgrade-deps": "npx taze -r --interactive",
    "check-deps": "npx taze -r"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@types/node": "^22.15.18",
    "ava": "^6.3.0",
    "c8": "^10.1.3",
    "esbuild-register": "^3.6.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "keywords": [],
  "author": "Thada Wangthammang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thaitype/uncoverage.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://github.com/thaitype/uncoverage#readme",
  "ava": {
    "extensions": [
      "ts"
    ],
    "require": [
      "esbuild-register"
    ]
  },
  "dependencies": {
    "ansis": "^4.0.0",
    "cleye": "^1.3.4",
    "clipboardy": "^4.0.0",
    "globby": "^14.1.0",
    "istextorbinary": "^9.5.0",
    "pretty-bytes": "^7.0.0"
  }
}